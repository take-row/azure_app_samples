{
  "routes": [
    {
      "route": "/*",
      "allowedRoles": ["vip"]
    }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad", "statusCode": 302 },
    "403": { "redirect": "/403.html", "statusCode": 302 }
  },
    "navigationFallback": {
      "rewrite": "/index.html"
    },
    "networking": {
      "allowedIpRanges": [
        "xxx.xxxx.xxxx.xxxx"
      ]
    }
  }